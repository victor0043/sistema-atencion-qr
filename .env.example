# Copiar a .env en la raíz del repo antes de correr docker-compose up --build
# Valores simples a propósito (proyecto de curso) - el objetivo es el mecanismo
# de entrega de secretos vía env_file, no la fortaleza del secreto en sí.

DB_PASSWORD=admin123
JWT_SECRET=HospitalQR2026
INTERNAL_API_KEY=secret-internal-key

# Lista separada por comas de orígenes permitidos por CORS en los 5 servicios backend.
# El frontend corre en http://localhost:5173 (ver docker-compose.yml).
ALLOWED_ORIGINS=http://localhost:5173

# URL interna (nombre de servicio Docker, no localhost) que appointment-service usa
# para notificar a admin-service el cambio de estado de un médico al finalizar una
# cita. Ya está fijada como valor literal en docker-compose.yml para
# appointment-service; se documenta aquí para referencia.
ADMIN_SERVICE_URL=http://admin-service:3001

# URL interna que admin-service usa para consultar las citas de appointment-service
# y derivar el campo "estado" de cada médico en GET /api/admin/medicos. Ya está
# fijada como valor literal en docker-compose.yml para admin-service; se
# documenta aquí para referencia.
APPOINTMENT_SERVICE_URL=http://appointment-service:3002
